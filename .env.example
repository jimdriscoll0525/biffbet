# Copy this file to ".env" and fill in your values.
# The .env file is read at startup via python-dotenv.

# --- The Odds API (https://the-odds-api.com) ---
# Free tier gives 500 requests/month. Each "today" run uses 1 request.
ODDS_API_KEY=your_odds_api_key_here

# --- Bankroll used for Kelly stake sizing (any currency unit you like) ---
BANKROLL=1000

# --- Optional: override the log level (DEBUG, INFO, WARNING, ERROR) ---
LOG_LEVEL=INFO

# --- Supabase (powers the public BiffBet web dashboard via `sync`) ---
# Dashboard -> Project Settings -> API. The SERVICE key is a secret: it bypasses
# row-level security and must NEVER be exposed to the browser / committed to git.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_secret_here
